class Solution {
boolean isPalindrome(String s) {
return check(s, 0, s.length() - 1);
}
boolean check(String s, int start, int end) {
// Base case
if (start >= end) {
return true;
}
// Mismatch
if (s.charAt(start) != s.charAt(end)) {
return false;
}
// Recursive call
return check(s, start + 1, end - 1);
    }
}
